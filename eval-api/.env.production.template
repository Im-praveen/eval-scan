# ------------------------------------------------------------------------------
# EvalScan — PRODUCTION ENVIRONMENT CONFIGURATION (AWS EC2 Monolith)
# ------------------------------------------------------------------------------

# General
NODE_ENV=production
PORT=3000

# Database
# Replace with your local MongoDB string or Atlas URI
MONGO_URI=mongodb://localhost:27017/evalscan
CORS_ORIGIN=https://yourdomain.com

# Security
JWT_SECRET=YOUR_PRODUCTION_JWT_SECRET_HERE
API_KEY=YOUR_PRODUCTION_API_KEY_HERE

# Filesystem (AWS EBS mounted volume paths)
UPLOADS_DIR=/data/evalscan/uploads
EXTRACTED_DIR=/data/evalscan/extracted
RESULTS_DIR=/data/evalscan/results

# OMR Engine (Pinned to OpenJDK 11)
JAR_PATH=/data/evalscan/evalomr.jar
TEMPLATE_PATH=
